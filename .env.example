# ── Anthropic API (direct) ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OR: Proxy / Gateway ──────────────────────────────────────────────────────
# HERMIT_AUTH_TOKEN=your-bearer-token
# HERMIT_BASE_URL=https://your-proxy.example.com/llm/claude
# HERMIT_CUSTOM_HEADERS=X-Biz-Id: claude-code
# HERMIT_MODEL=claude-3-7-sonnet-latest

# ── Feishu bot adapter (optional) ────────────────────────────────────────────
# HERMIT_FEISHU_APP_ID=cli_xxx
# HERMIT_FEISHU_APP_SECRET=your-app-secret

# ── Tuning (optional) ────────────────────────────────────────────────────────
# HERMIT_MAX_TOKENS=4096
# HERMIT_MAX_TURNS=50
# HERMIT_THINKING_BUDGET=8000
# HERMIT_LOG_LEVEL=INFO
